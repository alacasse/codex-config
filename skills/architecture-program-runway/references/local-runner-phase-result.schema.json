{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Local Architecture Program Runner Phase Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "phase",
    "next_phase",
    "stop_reason",
    "program_ledger",
    "batch_id",
    "dispatch_path",
    "spec_path",
    "receipt_path",
    "commit_range",
    "validation_summary",
    "review_summary",
    "evidence_paths"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "stopped", "failed"]
    },
    "phase": {
      "type": "string",
      "enum": ["select-dispatch", "create-spec", "execute", "closeout"]
    },
    "next_phase": {
      "type": "string",
      "enum": [
        "select-dispatch",
        "create-spec",
        "execute",
        "closeout",
        "done",
        "stopped"
      ]
    },
    "stop_reason": {
      "type": ["string", "null"]
    },
    "program_ledger": {
      "type": "string",
      "minLength": 1
    },
    "batch_id": {
      "type": ["string", "null"]
    },
    "dispatch_path": {
      "type": ["string", "null"]
    },
    "spec_path": {
      "type": ["string", "null"]
    },
    "receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "commit_range": {
      "type": ["string", "null"]
    },
    "validation_summary": {
      "type": ["string", "null"]
    },
    "review_summary": {
      "type": ["string", "null"]
    },
    "evidence_paths": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    }
  }
}
